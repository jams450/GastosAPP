# ============================================
# GastosApp - Variables de Entorno
# ============================================

# JWT Configuration (mínimo 32 caracteres)
# Generar con: openssl rand -base64 32
JWT_KEY=cambia-esto-por-una-clave-segura-de-32-caracteres-o-mas

# Session secret de frontend Next.js (mínimo 32 caracteres)
# Generar con: openssl rand -base64 32
SESSION_SECRET=cambia-esto-por-una-clave-segura-de-32-caracteres-o-mas

# Admin auth para API
AUTH_USERNAME=admin
AUTH_PASSWORD=cambia-esto-por-password-admin-seguro

# Cifrado usado por PasswordService (AES)
ENCRYPTION_KEY=cambia-esto-por-32-caracteres-minimo
ENCRYPTION_IV=cambia-esto-por-16-caracteres-minimo

# Database
DB_PASSWORD=tu-password-segura-para-postgres

# URLs / dominios
# En Docker Compose, API_BASE_URL debe apuntar al servicio interno de API
# (por defecto en compose: http://api:8080)
API_BASE_URL=http://api:8080
CORS_ALLOWED_ORIGINS=https://tu-frontend-dominio.com,https://tu-api-dominio.com

# Notas:
# 1. JWT_KEY: Usada por la API .NET para firmar tokens
# 2. SESSION_SECRET: Usada por Next.js para encriptar cookies de sesión
# 3. DB_PASSWORD: Password para PostgreSQL
# 4. AUTH_USERNAME/AUTH_PASSWORD: Credenciales admin de API
# 5. ENCRYPTION_KEY/ENCRYPTION_IV: Claves de cifrado para PasswordService
# 6. API_BASE_URL: URL interna que usa Next server-side para llamar a la API
# 7. CORS_ALLOWED_ORIGINS: Lista separada por comas
# 8. Generar claves seguras con: openssl rand -base64 32
# 9. NO compartir archivos .env reales en repositorios públicos
